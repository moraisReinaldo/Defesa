# ==============================================================
# TEMPLATE DE CONFIGURAÇÃO — application.properties.example
# ==============================================================
# Copie este arquivo para 'application.properties' e preencha
# os valores reais. O arquivo 'application.properties' é ignorado
# pelo Git e NUNCA deve ser versionado (contém senhas).
#
# No Mac Mini:
#   cp application.properties.example application.properties
#   nano application.properties  # preencher os valores abaixo
# ==============================================================

server.port=8080

# PostgreSQL Configuration
spring.datasource.url=${DATABASE_URL:jdbc:postgresql://localhost:5432/defesacivil_db}
spring.datasource.username=${DATABASE_USERNAME:SEU_USUARIO_DB}
spring.datasource.password=${DATABASE_PASSWORD:SUA_SENHA_DB}
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# MinIO Configuration
minio.endpoint=${MINIO_ENDPOINT:https://SEU_TUNNEL_MINIO.trycloudflare.com}
minio.access-key=${MINIO_ACCESS_KEY:admin}
minio.secret-key=${MINIO_SECRET_KEY:SUA_SENHA_MINIO}
minio.bucket-name=${MINIO_BUCKET:defesa-civil}

# Admin password — OBRIGATÓRIO configurar
# Pode ser texto plano (dev) ou hash BCrypt (produção)
app.admin.password=${APP_ADMIN_PASSWORD:SUA_SENHA_ADMIN}

# JWT Secret - OBRIGATÓRIO 32+ caracteres
app.jwt.secret=${APP_JWT_SECRET:SuaChaveSuperSecretaComMaisDe32Caracteres}

# Mail Configuration
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${MAIL_USERNAME:}
spring.mail.password=${MAIL_PASSWORD:}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

# Email de destino para notificações de admin
app.admin.notification.email=${ADMIN_NOTIFICATION_EMAIL:seu_email@gmail.com}

# CORS
spring.web.cors.allowed-origin-patterns=${CORS_ALLOWED_ORIGINS:*}

# Actuator — Expor APENAS o health check
management.endpoints.web.exposure.include=health
management.endpoint.health.show-details=never

# Performance - Compressão Gzip
server.compression.enabled=true
server.compression.mime-types=application/json,application/xml,text/html,text/xml,text/plain
server.compression.min-response-size=1024

# Security Headers
server.server-header=DefesaCivil-API
server.error.include-stacktrace=never
server.error.include-message=always
server.error.include-binding-errors=always
