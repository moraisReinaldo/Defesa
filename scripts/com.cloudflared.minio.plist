<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  LaunchAgent: Cloudflare Quick Tunnel para o MinIO (porta 9000).
  Permite que o app Flutter acesse imagens do MinIO de qualquer lugar.
  A URL é logada em ~/logs/cloudflared-minio-error.log.

  Instalar:
    cp com.cloudflared.minio.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.cloudflared.minio.plist
-->
<dict>
  <key>Label</key>
  <string>com.cloudflared.minio</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/cloudflared</string>
    <string>tunnel</string>
    <string>--url</string>
    <string>http://localhost:9000</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/reinaldohenriquemorais/logs/cloudflared-minio.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/reinaldohenriquemorais/logs/cloudflared-minio-error.log</string>
</dict>
</plist>
